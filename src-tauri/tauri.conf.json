{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ebb",
  "version": "0.1.0",
  "identifier": "com.ebb.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ebb",
        "width": 1100,
        "height": 750,
        "minWidth": 1000,
        "minHeight": 750,
        "hiddenTitle": true,
        "titleBarStyle": "Transparent",
        "backgroundColor": "#FCF8EDCC"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": ["'self'", "https://*.apple.com", "https://api.music.apple.com", "https://authorize.music.apple.com", "https://idmsa.apple.com"],
        "frame-src": ["'self'", "https://*.apple.com", "https://authorize.music.apple.com", "https://idmsa.apple.com"],
        "script-src": ["'self'", "'unsafe-inline'", "'unsafe-eval'", "https://js-cdn.music.apple.com"],
        "img-src": ["'self'", "data:", "https://*.apple.com"],
        "style-src": ["'self'", "'unsafe-inline'"]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["ebb"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
